# ═══════════════════════════════════════════════════════════
# AuraNet — Production Environment Variables
# Copy this to .env and fill in real values before deploying
# ═══════════════════════════════════════════════════════════

# Your domain (no trailing slash)
DOMAIN=https://yourdomain.com

# PostgreSQL — USE STRONG PASSWORDS
POSTGRES_USER=auranet
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here
POSTGRES_DB=auranet
DATABASE_URL=postgresql+asyncpg://auranet:CHANGE_ME_strong_random_password_here@db:5432/auranet

# MinIO — USE STRONG PASSWORDS
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_at_least_16_chars
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=auranet-media
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_password_at_least_16_chars

# RabbitMQ — USE STRONG PASSWORDS
RABBITMQ_DEFAULT_USER=auranet
RABBITMQ_DEFAULT_PASS=CHANGE_ME_rabbitmq_password

RABBITMQ_URL=amqp://auranet:CHANGE_ME_rabbitmq_password@rabbitmq:5672/

# JWT — MUST be a long random string (run: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Frontend API URL — set to your domain or leave empty for same-origin via Nginx
NEXT_PUBLIC_API_URL=

# AI Worker — switch to "openai" and add real key for real AI
AI_PROVIDER=mock
OPENAI_API_KEY=sk-placeholder
