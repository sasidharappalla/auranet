# PostgreSQL
POSTGRES_USER=auranet
POSTGRES_PASSWORD=auranet_secret
POSTGRES_DB=auranet
DATABASE_URL=postgresql+asyncpg://auranet:auranet_secret@db:5432/auranet

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=auranet-media
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_PUBLIC_URL=http://localhost:9002

# RabbitMQ
RABBITMQ_DEFAULT_USER=auranet
RABBITMQ_DEFAULT_PASS=auranet_secret
RABBITMQ_URL=amqp://auranet:auranet_secret@rabbitmq:5672/

# JWT Auth
JWT_SECRET=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI Worker
AI_PROVIDER=mock
OPENAI_API_KEY=sk-placeholder
